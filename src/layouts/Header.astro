---
import Link from '@/components/base/Link.astro'
import ThemeToggle from '@/components/base/ThemeToggle.astro'
import { FAVICON, HEADER_LINKS, SITE } from '@/config'
import { Icon } from 'astro-icon/components'
---

<header-nav-component
  class="group/nav relative mx-auto block w-full max-w-4xl px-4 py-2"
>
  <div
    class="border-border/0 bg-background/0 group-[.expanded]/nav:border-border group-[.expanded]/nav:bg-background group-[.not-top]/site:border-border group-[.not-top]/site:bg-background dark:group-[.expanded]/nav:bg-muted dark:group-[.not-top]/site:bg-muted relative flex flex-wrap items-center justify-between gap-x-4 gap-y-0 rounded-2xl px-0 py-0 transition-[background-color,border-color,box-shadow,padding,margin] duration-300 ease-out group-[.expanded]/nav:px-2 group-[.expanded]/nav:py-1 group-[.expanded]/nav:shadow-[0_10px_24px_rgba(15,23,42,0.06)] group-[.not-top]/site:px-2 group-[.not-top]/site:py-1 group-[.not-top]/site:shadow-[0_10px_24px_rgba(15,23,42,0.06)] sm:flex-nowrap sm:rounded-[1.25rem]"
  >
    <Link
      href="/"
      class="z-20 order-1 flex shrink-0 items-center justify-center gap-3 transition-[margin] duration-300 group-[.not-top]/site:ms-1"
      aria-label={SITE.title}
    >
      <img src={FAVICON.svg} alt="Logo" class="size-5 sm:size-6" />
      <span
        class="font-caveat hidden h-full text-lg leading-none font-medium min-[440px]:block"
        >{SITE.title}</span
      >
    </Link>

    <div
      id="header-expand-content"
      class="border-border/0 group-[.expanded]/nav:border-border/60 order-3 grid basis-full grid-rows-[0fr] opacity-0 transition-[grid-template-rows,opacity,margin,border-color,padding] duration-300 ease-out group-[.expanded]/nav:mt-2 group-[.expanded]/nav:grid-rows-[1fr] group-[.expanded]/nav:border-t group-[.expanded]/nav:pt-2 group-[.expanded]/nav:opacity-100 sm:order-2 sm:mt-0 sm:flex sm:flex-1 sm:basis-auto sm:justify-end sm:border-0 sm:p-0 sm:opacity-100"
    >
      <nav
        class="flex min-h-0 flex-col items-stretch justify-center overflow-hidden text-sm sm:flex-row sm:items-center sm:justify-end sm:gap-1"
        aria-label="Main navigation"
      >
        {
          HEADER_LINKS.map((item) => {
            const baseClass =
              'text-foreground/70 hover:text-foreground flex items-center justify-end gap-1.5 px-1 py-2 font-semibold capitalize transition-colors sm:px-3 sm:py-1.5'

            let linkClass = baseClass
            if (item.hideBelowPx) {
              const breakpoint = item.hideBelowPx
              linkClass = `hidden min-[${breakpoint}px]:flex ${baseClass}`
            }

            return (
              <Link href={item.href} class={linkClass}>
                {item.icon && <Icon name={item.icon} class="size-4" />}
                {item.label}
              </Link>
            )
          })
        }
      </nav>
    </div>

    <div
      class="z-20 order-2 ml-auto flex items-center gap-3 transition-[gap] duration-300 group-[.not-top]/site:gap-1.5 sm:order-3 sm:ml-0"
    >
      <ThemeToggle transition:persist />
      <button
        id="header-menu-toggle"
        type="button"
        class="text-foreground/65 hover:text-foreground border-border hover:bg-muted/60 relative inline-flex size-8 items-center justify-center rounded-md border transition-colors group-[.not-top]/site:rounded-xl sm:hidden"
        aria-label="Toggle menu"
        aria-controls="header-expand-content"
        aria-expanded="false"
      >
        <Icon
          name="lucide:menu"
          class="menu-icon size-4 transition-transform duration-200 group-[.expanded]/nav:scale-0 group-[.expanded]/nav:rotate-90"
          aria-hidden="true"
        />
        <Icon
          name="lucide:x"
          class="close-icon absolute size-4 scale-0 transition-transform duration-200 group-[.expanded]/nav:scale-100"
          aria-hidden="true"
        />
      </button>
    </div>
  </div>
</header-nav-component>

<script>
  class HeaderNav extends HTMLElement {
    private toggleButton: HTMLButtonElement | null = null
    private closingTimer: number | null = null
    private closeMenu = () => {
      if (this.classList.contains('expanded')) this.setExpanded(false)
    }

    connectedCallback() {
      this.toggleButton = this.querySelector('#header-menu-toggle')
      this.toggleButton?.addEventListener('click', this.handleToggle)
      this.querySelectorAll('a').forEach((link) =>
        link.addEventListener('click', this.closeMenu),
      )
      document.addEventListener('astro:before-swap', this.closeMenu)
    }

    disconnectedCallback() {
      this.toggleButton?.removeEventListener('click', this.handleToggle)
      this.querySelectorAll('a').forEach((link) =>
        link.removeEventListener('click', this.closeMenu),
      )
      document.removeEventListener('astro:before-swap', this.closeMenu)
      if (this.closingTimer) window.clearTimeout(this.closingTimer)
    }

    private handleToggle = () => {
      this.setExpanded(!this.classList.contains('expanded'))
    }

    private setExpanded(expanded: boolean) {
      const wasExpanded = this.classList.contains('expanded')
      if (wasExpanded === expanded) return

      document.dispatchEvent(new CustomEvent('site-header:force-show'))
      if (this.closingTimer) {
        window.clearTimeout(this.closingTimer)
        this.closingTimer = null
      }

      this.classList.toggle('collapsing', wasExpanded && !expanded)
      this.classList.toggle('expanded', expanded)
      this.toggleButton?.setAttribute('aria-expanded', String(expanded))
      document
        .getElementById('main-header')
        ?.classList.toggle('expanded', expanded)
      if (!expanded) {
        requestAnimationFrame(() =>
          document.dispatchEvent(new CustomEvent('site-header:force-show')),
        )
        this.closingTimer = window.setTimeout(() => {
          this.classList.remove('collapsing')
          this.closingTimer = null
        }, 320)
      }
    }
  }

  if (!customElements.get('header-nav-component')) {
    customElements.define('header-nav-component', HeaderNav)
  }
</script>

<style is:global>
  header-nav-component.collapsing > div {
    border-color: color-mix(in oklch, var(--border) 92%, transparent);
    background-color: color-mix(in oklch, var(--background) 98%, transparent);
    box-shadow:
      0 1px 0 color-mix(in oklch, white 70%, transparent) inset,
      0 14px 34px rgba(15, 23, 42, 0.13);
    padding: 0.25rem 0.5rem;
  }

  [data-theme='dark'] header-nav-component.collapsing > div {
    border-color: color-mix(in oklch, var(--border) 62%, transparent);
    background-color: color-mix(in oklch, var(--muted) 96%, black 4%);
    box-shadow: 0 16px 38px rgba(0, 0, 0, 0.34);
  }
</style>
