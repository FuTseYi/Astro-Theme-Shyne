---
import { ScrollArea } from '@/components/ui/scroll-area'
import type { TOCSection } from '@/lib/data-utils'
import { getParentId, isSubpost } from '@/lib/data-utils'
import { cn, getTOCLevelClass } from '@/lib/utils'

type Props = {
  sections: TOCSection[]
  currentPostId: string
}

const { sections, currentPostId } = Astro.props
const isCurrentSubpost = isSubpost(currentPostId)
const parentId = isCurrentSubpost ? getParentId(currentPostId) : currentPostId
---

{
  sections.length > 0 && (
    <div
      id="toc-sidebar-container"
      class="sticky top-20 col-start-1 mr-8 ml-auto hidden max-h-[calc(100vh-5rem)] max-w-md self-start xl:block"
    >
      <ScrollArea
        client:load
        className="flex max-h-[calc(100vh-8rem)] flex-col overflow-y-auto"
        type="hover"
        data-toc-scroll-area
      >
        <div class="flex flex-col gap-2 px-4">
          <span class="text-lg font-medium">Table of Contents</span>
          {sections.map((section, index) => {
            const isFirstSubpost =
              section.type === 'subpost' &&
              (index === 0 || sections[index - 1].type === 'parent')

            return (
              <>
                {isFirstSubpost && (
                  <div class="mt-2 flex items-center gap-2">
                    <div class="bg-border h-px flex-1" />
                    <span class="text-muted-foreground text-xs font-medium">
                      Subposts
                    </span>
                    <div class="bg-border h-px flex-1" />
                  </div>
                )}

                {section.type === 'parent' ? (
                  <ul class="flex list-none flex-col gap-y-2">
                    {section.headings.map((heading) => (
                      <li
                        data-toc-item
                        data-heading-depth={heading.displayDepth}
                        class={cn(
                          'border-border/40 relative border-l py-0.5 pl-3 transition-colors before:absolute before:top-1 before:bottom-1 before:left-[-1px] before:w-0.5 before:rounded-full before:bg-transparent',
                          getTOCLevelClass(heading.displayDepth),
                          isCurrentSubpost && 'opacity-60',
                        )}
                      >
                        <a
                          href={
                            isCurrentSubpost
                              ? `/blog/${parentId}#${heading.slug}`
                              : `#${heading.slug}`
                          }
                          class="toc-link marker:text-foreground/30 focus-visible:ring-ring block list-none rounded-sm px-1 py-0.5 leading-snug [overflow-wrap:anywhere] break-words whitespace-normal underline decoration-transparent underline-offset-[3px] transition-colors duration-200 hover:decoration-inherit focus-visible:ring-2 focus-visible:outline-none"
                          data-heading-link={heading.slug}
                        >
                          {heading.text}
                        </a>
                      </li>
                    ))}
                  </ul>
                ) : (
                  <div
                    class={cn(
                      'rounded-md border p-2',
                      section.subpostId === currentPostId ? 'bg-muted/50' : '',
                    )}
                  >
                    <ul class="flex list-none flex-col gap-y-2">
                      <li
                        class={cn(
                          'text-xs font-medium',
                          section.subpostId === currentPostId
                            ? 'text-foreground'
                            : 'text-foreground/60',
                        )}
                      >
                        <a
                          href={
                            section.subpostId === currentPostId
                              ? '#'
                              : `/blog/${section.subpostId}`
                          }
                          class="marker:text-foreground/30 list-none underline decoration-transparent underline-offset-[3px] transition-colors duration-200 hover:decoration-inherit"
                          data-heading-link={
                            section.subpostId === currentPostId
                              ? 'top'
                              : `${section.subpostId}-top`
                          }
                        >
                          {section.title}
                        </a>
                      </li>
                      {section.headings.map((heading) => (
                        <li
                          data-toc-item
                          data-heading-depth={heading.displayDepth}
                          class={cn(
                            'border-border/35 relative border-l py-0.5 pl-3 transition-colors before:absolute before:top-1 before:bottom-1 before:left-[-1px] before:w-0.5 before:rounded-full before:bg-transparent',
                            getTOCLevelClass(heading.displayDepth),
                            section.subpostId !== currentPostId && 'opacity-55',
                          )}
                        >
                          <a
                            href={
                              section.subpostId === currentPostId
                                ? `#${heading.slug}`
                                : `/blog/${section.subpostId}#${heading.slug}`
                            }
                            class="toc-link marker:text-foreground/30 hover:text-foreground/60 focus-visible:ring-ring block list-none rounded-sm px-1 py-0.5 leading-snug [overflow-wrap:anywhere] break-words whitespace-normal underline decoration-transparent underline-offset-[3px] transition-colors duration-200 hover:decoration-inherit focus-visible:ring-2 focus-visible:outline-none"
                            data-heading-link={
                              section.subpostId === currentPostId
                                ? heading.slug
                                : `${section.subpostId}-${heading.slug}`
                            }
                          >
                            {heading.text}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </>
            )
          })}
        </div>
      </ScrollArea>
    </div>
  )
}

<script>
  const HEADER_OFFSET = 150
  const BOTTOM_THRESHOLD = 24

  type HeadingEntry = {
    id: string
    depth: number
    top: number
  }

  class TOCState {
    links: NodeListOf<Element> = document.querySelectorAll(
      '[data-heading-link]',
    )
    activeIds: string[] = []
    headings: HeadingEntry[] = []
    scrollArea: HTMLElement | null = null
    tocScrollArea: HTMLElement | null = null

    reset() {
      this.links = document.querySelectorAll(
        '#toc-sidebar-container [data-heading-link]',
      )
      this.activeIds = []
      this.headings = []
      const tocContainer = document.getElementById('toc-sidebar-container')
      this.scrollArea =
        tocContainer?.querySelector('[data-radix-scroll-area-viewport]') || null
      this.tocScrollArea =
        tocContainer?.querySelector('[data-toc-scroll-area]') || null
    }
  }

  const state = new TOCState()

  const scrollToHashWithOffset = (behavior = 'auto') => {
    if (!window.location.hash) return

    const targetId = decodeURIComponent(window.location.hash.slice(1))
    if (!targetId) return

    const target = document.getElementById(targetId)
    if (!target) return

    const prefersReducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches

    const finalBehavior =
      prefersReducedMotion || behavior !== 'smooth' ? 'auto' : 'smooth'

    const targetTop =
      target.getBoundingClientRect().top + window.scrollY - HEADER_OFFSET

    window.scrollTo({
      top: Math.max(targetTop, 0),
      behavior: finalBehavior,
    })
  }

  class HeadingRegions {
    static getDepth(heading: Element): number {
      const level = Number(heading.tagName.toLowerCase().replace('h', ''))
      return Number.isNaN(level) ? 6 : level
    }

    static build() {
      state.headings = Array.from(
        document.querySelectorAll<HTMLElement>(
          '.prose h1, .prose h2, .prose h3, .prose h4, .prose h5, .prose h6',
        ),
      ).map((heading) => ({
        id: heading.id,
        depth: this.getDepth(heading),
        top: heading.getBoundingClientRect().top + window.scrollY,
      }))
    }

    static isAtPageEnd(): boolean {
      const maxScrollY = Math.max(
        0,
        document.documentElement.scrollHeight - window.innerHeight,
      )

      return window.scrollY >= maxScrollY - BOTTOM_THRESHOLD
    }

    static getHeadingPath(currentIndex: number): string[] {
      const currentHeading = state.headings[currentIndex]
      if (!currentHeading) return []

      const path = [currentHeading.id]
      let nextAncestorDepth = currentHeading.depth - 1

      for (let i = currentIndex - 1; i >= 0 && nextAncestorDepth >= 1; i -= 1) {
        const candidate = state.headings[i]

        if (candidate.depth <= nextAncestorDepth) {
          path.unshift(candidate.id)
          nextAncestorDepth = candidate.depth - 1
        }
      }

      return path
    }

    static getVisibleIds(): string[] {
      if (state.headings.length === 0) return []

      if (this.isAtPageEnd()) {
        return this.getHeadingPath(state.headings.length - 1)
      }

      const anchorY = window.scrollY + HEADER_OFFSET + 8
      let currentIndex = state.headings.findLastIndex(
        (heading) => heading.top <= anchorY,
      )

      if (currentIndex < 0) currentIndex = 0

      return this.getHeadingPath(currentIndex)
    }
  }

  class TOCScrollMask {
    static update() {
      if (!state.scrollArea || !state.tocScrollArea) return

      const { scrollTop, scrollHeight, clientHeight } = state.scrollArea
      const threshold = 5
      const isAtTop = scrollTop <= threshold
      const isAtBottom = scrollTop >= scrollHeight - clientHeight - threshold

      state.tocScrollArea.classList.toggle('mask-t-from-90%', !isAtTop)
      state.tocScrollArea.classList.toggle('mask-b-from-90%', !isAtBottom)
    }
  }

  class TOCLinks {
    static findLinkByHeadingId(id: string): HTMLElement | null {
      for (const link of state.links) {
        if ((link as HTMLElement).dataset.headingLink === id) {
          return link as HTMLElement
        }
      }

      return null
    }

    static update(headingIds: string[]) {
      state.links.forEach((link) => {
        link.classList.remove('text-foreground')
        link.classList.remove('font-medium')
        link.removeAttribute('aria-current')

        const item = link.closest('[data-toc-item]')
        item?.classList.remove('toc-item-active')
      })

      headingIds.forEach((id, index) => {
        if (id) {
          const activeLink = this.findLinkByHeadingId(id)
          if (activeLink) {
            activeLink.classList.add('text-foreground')
            if (index === headingIds.length - 1) {
              activeLink.classList.add('font-medium')
              activeLink.setAttribute('aria-current', 'location')
            }

            const item = activeLink.closest('[data-toc-item]')
            item?.classList.add('toc-item-active')
          }
        }
      })

      this.scrollToActive(headingIds)
    }

    static scrollToActive(headingIds: string[]) {
      if (!state.scrollArea || !headingIds.length) return

      const activeLink = this.findLinkByHeadingId(
        headingIds[headingIds.length - 1],
      )
      if (!activeLink) return

      const { top: areaTop, height: areaHeight } =
        state.scrollArea.getBoundingClientRect()
      const { top: linkTop, height: linkHeight } =
        activeLink.getBoundingClientRect()

      const currentLinkTop = linkTop - areaTop + state.scrollArea.scrollTop
      const targetScroll = Math.max(
        0,
        Math.min(
          currentLinkTop - (areaHeight - linkHeight) / 2,
          state.scrollArea.scrollHeight - state.scrollArea.clientHeight,
        ),
      )

      if (Math.abs(targetScroll - state.scrollArea.scrollTop) > 5) {
        state.scrollArea.scrollTop = targetScroll
      }
    }
  }

  const setupSmoothScrollForSamePageLinks = () => {
    state.links.forEach((linkEl) => {
      const link = linkEl as HTMLAnchorElement

      // 避免在多次 init 时重复绑定事件，导致多次 pushState
      if (link.dataset.tocBound === 'true') return
      link.dataset.tocBound = 'true'

      link.addEventListener('click', (event) => {
        const url = new URL(link.href, window.location.href)

        if (url.pathname !== window.location.pathname || !url.hash) return

        const targetId = decodeURIComponent(url.hash.slice(1))
        const target = document.getElementById(targetId)
        if (!target) return

        event.preventDefault()

        window.history.pushState(null, '', url.hash)

        scrollToHashWithOffset('smooth')
      })
    })
  }

  const hasSameIds = (a: string[], b: string[]) =>
    a.length === b.length && a.every((id, index) => id === b[index])

  class TOCController {
    static scrollFrame: number | null = null

    static updateActive() {
      const newActiveIds = HeadingRegions.getVisibleIds()

      if (!hasSameIds(newActiveIds, state.activeIds)) {
        state.activeIds = newActiveIds
        TOCLinks.update(state.activeIds)
      }
    }

    static handleScroll = () => {
      if (this.scrollFrame !== null) return

      this.scrollFrame = window.requestAnimationFrame(() => {
        this.scrollFrame = null
        this.updateActive()
      })
    }

    static handleTOCScroll = () => TOCScrollMask.update()

    static handleResize = () => {
      HeadingRegions.build()
      this.updateActive()
      TOCScrollMask.update()
    }

    static handlePopState = () => {
      scrollToHashWithOffset('auto')
    }

    static init() {
      state.reset()
      HeadingRegions.build()

      if (state.headings.length === 0) {
        TOCLinks.update([])
        return
      }

      this.updateActive()
      setTimeout(TOCScrollMask.update, 100)
      setupSmoothScrollForSamePageLinks()
      scrollToHashWithOffset('auto')

      const options = { passive: true }
      window.addEventListener('scroll', this.handleScroll, options)
      window.addEventListener('resize', this.handleResize, options)
      window.addEventListener('load', this.handleResize, {
        once: true,
        passive: true,
      })
      window.addEventListener('popstate', this.handlePopState)
      state.scrollArea?.addEventListener(
        'scroll',
        this.handleTOCScroll,
        options,
      )
    }

    static cleanup() {
      if (this.scrollFrame !== null) {
        window.cancelAnimationFrame(this.scrollFrame)
        this.scrollFrame = null
      }

      window.removeEventListener('scroll', this.handleScroll)
      window.removeEventListener('resize', this.handleResize)
      window.removeEventListener('load', this.handleResize)
      window.removeEventListener('popstate', this.handlePopState)
      state.scrollArea?.removeEventListener('scroll', this.handleTOCScroll)

      Object.assign(state, {
        activeIds: [],
        headings: [],
        scrollArea: null,
        tocScrollArea: null,
      })
    }
  }

  type TOCSidebarLifecycle = {
    init: () => void
    cleanup: () => void
  }

  const tocWindow = window as Window & {
    __shyneTOCSidebar?: TOCSidebarLifecycle
  }

  if (tocWindow.__shyneTOCSidebar) {
    document.removeEventListener(
      'astro:page-load',
      tocWindow.__shyneTOCSidebar.init,
    )
    document.removeEventListener(
      'astro:after-swap',
      tocWindow.__shyneTOCSidebar.init,
    )
    document.removeEventListener(
      'astro:before-swap',
      tocWindow.__shyneTOCSidebar.cleanup,
    )
    tocWindow.__shyneTOCSidebar.cleanup()
  }

  const lifecycle: TOCSidebarLifecycle = {
    init: () => {
      TOCController.cleanup()
      TOCController.init()
    },
    cleanup: () => TOCController.cleanup(),
  }

  tocWindow.__shyneTOCSidebar = lifecycle

  document.addEventListener('astro:page-load', lifecycle.init)
  document.addEventListener('astro:after-swap', lifecycle.init)
  document.addEventListener('astro:before-swap', lifecycle.cleanup)

  lifecycle.init()
</script>

<style>
  #toc-sidebar-container .toc-item-active {
    border-left-color: hsl(var(--primary) / 0.55);
    background-color: hsl(var(--muted) / 0.35);
    border-radius: 0.375rem;
    color: hsl(var(--foreground));
    opacity: 1;
  }

  #toc-sidebar-container .toc-item-active::before {
    background-color: hsl(var(--primary));
  }
</style>
