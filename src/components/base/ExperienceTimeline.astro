---
// Astro
import { Image } from 'astro:assets'

// Components
import Link from './Link.astro'
import { Badge } from '@/components/ui/badge'

// Utils & Types
import { cn } from '@/lib/utils'
import { compareExperiences } from '@/lib/data-utils'
import type { CollectionEntry } from 'astro:content'

interface Props {
  experiences: CollectionEntry<'experience'>[]
}

const { experiences } = Astro.props

// 格式化日期函数
const formatDate = (date: Date | null | undefined): string => {
  if (!date) return ''
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'short',
  }).format(date)
}

const getDateRange = (exp: CollectionEntry<'experience'>) => {
  const start = formatDate(exp.data.startDate)
  if (!start) return ''

  const end = formatDate(exp.data.endDate)
  if (end) {
    return `${start} - ${end}`
  }

  // 如果没有 endDate，显示 Present
  return `${start} - Present`
}

const isCurrentExperience = (exp: CollectionEntry<'experience'>) => {
  return !exp.data.endDate
}

const getCompanyUrl = (exp: CollectionEntry<'experience'>): string | null => {
  const url = exp.data.companyUrl
  if (typeof url !== 'string') return null
  const trimmed = url.trim()
  return trimmed.length > 0 ? trimmed : null
}

const getInitials = (company: string | null | undefined): string => {
  const text = (company ?? '').trim()
  if (!text) return '?'
  const parts = text.split(/\s+/).filter(Boolean)
  const first = parts[0]?.[0] ?? ''
  const second = parts.length > 1 ? parts[1]?.[0] ?? '' : ''
  return (first + second).toUpperCase() || '?'
}

// Keep sorting here for safety (component might be used with unsorted data),
// but ensure there's exactly one sorting rule by reusing the shared comparator.
const sortedExperiences = [...experiences].sort(compareExperiences)
---

<div class="space-y-8">
  {
    sortedExperiences.map((exp, index) => {
      const companyUrl = getCompanyUrl(exp)
      const initials = getInitials(exp.data.company)
      const dateRange = getDateRange(exp)
      const location = exp.data.location?.trim()

      return (
        <div class="relative">
          {index < sortedExperiences.length - 1 && (
            <div
              class="bg-border absolute top-14 bottom-[-2rem] left-[19px] w-px"
              aria-hidden="true"
            />
          )}

          <div class="flex gap-5">
            {/* Company Logo */}
            {companyUrl ? (
              <Link href={companyUrl} external class="relative block shrink-0">
                <div
                  class={cn(
                    'border-border z-10 flex h-10 w-10 items-center justify-center overflow-hidden rounded-full border',
                    isCurrentExperience(exp) &&
                      'shadow-primary/20 shadow-lg dark:shadow-none',
                  )}
                >
                  {exp.data.companyLogo ? (
                    <Image
                      src={exp.data.companyLogo}
                      alt={
                        exp.data.company
                          ? `${exp.data.company} logo`
                          : 'Company logo'
                      }
                      width={40}
                      height={40}
                      class="bg-background dark:bg-border h-full w-full object-contain p-1.5 transition-opacity hover:opacity-80"
                    />
                  ) : (
                    <span class="text-muted-foreground text-xs font-semibold">
                      {initials}
                    </span>
                  )}
                </div>
              </Link>
            ) : (
              <div
                class={cn(
                  'border-border z-10 flex h-10 w-10 items-center justify-center overflow-hidden rounded-full border',
                  isCurrentExperience(exp) &&
                    'shadow-primary/20 shadow-lg dark:shadow-none',
                )}
              >
                {exp.data.companyLogo ? (
                  <Image
                    src={exp.data.companyLogo}
                    alt={
                      exp.data.company ? `${exp.data.company} logo` : 'Company logo'
                    }
                    width={40}
                    height={40}
                    class="bg-background dark:bg-border h-full w-full object-contain p-1.5"
                  />
                ) : (
                  <span class="text-muted-foreground text-xs font-semibold">
                    {initials}
                  </span>
                )}
              </div>
            )}

            <div class="min-w-0 flex-1">
              <div class="space-y-1">
                {/* Role Name */}
                <div class="flex items-start justify-between gap-4">
                  <h3 class="text-foreground text-lg leading-tight font-semibold">
                    {exp.data.role}
                  </h3>
                  {isCurrentExperience(exp) && (
                    <span class="inline-flex items-center gap-1 rounded-full border border-green-500/20 bg-green-500/10 px-2 py-0.5 text-xs font-medium text-green-600 dark:text-green-400">
                      <span class="h-1.5 w-1.5 rounded-full bg-green-500 dark:bg-green-400" />
                      Active
                    </span>
                  )}
                </div>

                {/* Company Name */}
                <p class="text-muted-foreground text-sm">{exp.data.company}</p>

                {/* Period and Location */}
                <p class="text-muted-foreground text-sm">
                  {dateRange && <span class="font-semibold">{dateRange}</span>}
                  {dateRange && location && <span class="mx-2">·</span>}
                  {location}
                </p>
              </div>

              {/* Description */}
              <p class="text-muted-foreground/90 mt-2 text-sm leading-relaxed">
                {exp.data.description}
              </p>

              {/* Tags - same structure as blog: array of strings */}
              {exp.data.tags && exp.data.tags.length > 0 && (
                <div class="mt-4 flex flex-wrap gap-1.5">
                  {exp.data.tags.map((tag: string) => (
                    <Badge
                      variant="muted"
                      className="flex bg-muted/30 border border-border"
                    >
                      {tag}
                    </Badge>
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
      )
    })
  }
</div>
