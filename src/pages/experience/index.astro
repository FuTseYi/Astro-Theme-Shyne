---
import Breadcrumbs from '@/components/base/Breadcrumbs.astro'
import PageHead from '@/components/posts/base/PageHead.astro'
import ExperienceTimeline from '@/components/base/ExperienceTimeline.astro'
import Layout from '@/layouts/Layout.astro'
import { getAllExperiences } from '@/lib/data-utils'

const experiences = await getAllExperiences()
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Experience" />
  <Breadcrumbs
    items={[
      { label: 'Experience', href: '/experience', icon: 'lucide:briefcase-business' },
    ]}
  />

  <section class="mt-8">
    <ExperienceTimeline experiences={experiences} />
  </section>
</Layout>

