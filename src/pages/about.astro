---
// Components
import Breadcrumbs from '@/components/base/Breadcrumbs.astro'
import PageHead from '@/components/posts/base/PageHead.astro'

// Layouts
import Layout from '@/layouts/Layout.astro'
import { Image } from 'astro:assets'

// Custom
import heroImageOne from '/public/hero/1.png'
import heroImageTwo from '/public/hero/2.png'
---

<!-- OUTLINE (basically it should be a ME page)
  - Hero Section With SubSection and text
  - Image Gallery of Me (bento box style)
-->
<Layout class="max-w-3xl">
  <PageHead slot="head" title="About" />
  <Breadcrumbs items={[{ label: 'About', icon: 'lucide:user-star' }]} />
  <div class="about-page flex flex-col gap-y-8">
    <!-- Header section with profile photos -->
    <section
      class="bg-grid-pattern flex flex-col items-center gap-6 p-6 pb-0 text-center"
    >
      <div class="relative flex items-center justify-center">
        <!-- one Profile -->
        <div
          class="group relative z-0 w-42 -rotate-2 bg-white p-2 pb-10 shadow-lg transition-all duration-300 hover:scale-105 hover:rotate-[-4deg] hover:shadow-xl"
        >
          <Image
            src={heroImageOne}
            alt="Profile 1"
            class="relative block h-auto w-full border border-gray-200"
          />
          <p
            class="font-caveat absolute bottom-2 left-1/2 -translate-x-1/2 text-base whitespace-nowrap text-gray-800"
          >
            me again :)
          </p>
        </div>
        <!-- two Profile -->
        <div
          class="group relative z-10 -ml-8 w-48 translate-y-14 rotate-2 bg-white p-2 pb-10 shadow-lg transition-all duration-300 hover:scale-105 hover:rotate-4 hover:shadow-xl"
        >
          <Image
            src={heroImageTwo}
            alt="Profile 2"
            class="relative block h-auto w-full border border-gray-200"
          />
          <p
            class="font-caveat absolute bottom-2 left-1/2 -translate-x-1/2 text-base whitespace-nowrap text-gray-800"
          >
            the other me
          </p>
        </div>
      </div>
      <h1 class="font-bon-vivant pt-10 text-8xl font-bold">
        who's <br />
        <span class="text-accent font-caveat -mt-10 block text-7xl font-black"
          >Shyne?</span
        >
      </h1>
    </section>

    <!-- About Me Section -->
    <section>
      <div>
        <p
          class="prose prose-sm text-muted-foreground max-w-none text-center font-serif md:text-left"
        >
          Astro Theme Shyne came from a practical gap: many personal site themes
          look polished but break down when content grows. I wanted one
          foundation that could handle essays, changelogs, projects, and photo
          stories with equal clarity.
        </p>
        <p
          class="prose prose-sm text-muted-foreground mt-4 max-w-none text-center font-serif md:text-left"
        >
          The result is more than a homepage template. It is a narrative-first
          system: structured blog content, contextual project cards, and a
          Polaroid-style photo timeline that treats images as part of the story,
          not decoration.
        </p>
        <p
          class="prose prose-sm text-muted-foreground mt-4 max-w-none text-center font-serif md:text-left"
        >
          这个项目的目标很明确：把写作、记录、展示与归档放回同一条内容链路，
          用一致的设计与结构降低维护成本，同时保留个人表达的温度。
        </p>
        <p
          class="text-muted-foreground mt-4 max-w-none text-center font-serif leading-relaxed md:text-left"
        >
          This work is inspired by the craft and direction of
          <a
            href="https://github.com/theinfinull"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-accent underline underline-offset-4 transition-colors"
            >@theinfinull</a
          >
          and
          <a
            href="https://github.com/needim"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-accent underline underline-offset-4 transition-colors"
            >@needim</a
          >, then redesigned and expanded into an Astro-first open-source theme.
        </p>
      </div>
    </section>

    <!-- Tools Section -->
    <section>
      <h2 class="font-bon-vivant text-accent mb-4 text-5xl font-semibold">
        Tools, <span class="text-foreground font-sans text-4xl">you ask?</span>
      </h2>

      <ul
        class="text-muted-foreground mt-4 grid grid-cols-1 gap-3 text-left font-serif"
      >
        <li class="flex items-start gap-2">
          <span class="text-accent shrink-0">▹</span>
          <span class="inline-block">
            <strong class="text-foreground">Core runtime:</strong> Astro 5 / React
            19 / Tailwind CSS 4 / TypeScript
          </span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-accent shrink-0">▹</span>
          <span class="inline-block">
            <strong class="text-foreground">Content pipeline:</strong> Astro Content
            Collections / Markdown / Expressive Code
          </span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-accent shrink-0">▹</span>
          <span class="inline-block">
            <strong class="text-foreground">Authoring workflow:</strong> VS Code /
            Obsidian / Figma /
            <a
              href="https://realfavicongenerator.net/"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-accent underline underline-offset-4 transition-colors"
              >RealFaviconGenerator</a
            >
            (cross-platform favicon generation)
          </span>
        </li>
      </ul>
    </section>

    <!-- Website Overview Section -->
    <section>
      <h2 class="text-accent font-bon-vivant mb-4 text-6xl font-semibold">
        <span class="relative -top-1 inline-block">Website</span>
        <span class="text-foreground font-sans text-4xl">& Overview</span>
      </h2>

      <p
        class="text-muted-foreground max-w-3xl text-center font-serif leading-relaxed md:text-left"
      >
        The site is operated with a production-style setup where each layer has
        a clear responsibility, from DNS and edge delivery to hosting and
        framework.
      </p>
      <ul
        class="text-muted-foreground mt-4 flex flex-col space-y-2 text-left font-serif"
      >
        <li class="flex items-start gap-2">
          <span class="text-accent shrink-0">▹</span>
          <span class="inline-block">
            <strong class="text-foreground">Domain:</strong> Spaceship
          </span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-accent shrink-0">▹</span>
          <span class="inline-block">
            <strong class="text-foreground">DNS and edge proxy:</strong> Cloudflare
          </span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-accent shrink-0">▹</span>
          <span class="inline-block">
            <strong class="text-foreground">Hosting and deployment:</strong>
            Vercel
          </span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-accent shrink-0">▹</span>
          <span class="inline-block">
            <strong class="text-foreground">Framework and theme:</strong>
            Astro +
            <a
              href="https://github.com/FuTseYi/Astro-Theme-Shyne"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-accent underline underline-offset-4 transition-colors"
              >Astro-Theme-Shyne</a
            >
          </span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-accent shrink-0">▹</span>
          <span class="inline-block">
            <strong class="text-foreground">Inspiration lineage:</strong>
            <a
              href="https://github.com/theinfinull/portfolio"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-accent underline underline-offset-4 transition-colors"
              >theinfinull/portfolio</a
            >
            and
            <a
              href="https://github.com/needim/ned.im"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-accent underline underline-offset-4 transition-colors"
              >needim/ned.im</a
            >
          </span>
        </li>
      </ul>
    </section>
  </div>
</Layout>
