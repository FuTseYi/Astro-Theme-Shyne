---
// Components
import Breadcrumbs from '@/components/base/Breadcrumbs.astro'
import PageHead from '@/components/posts/base/PageHead.astro'

// Layouts
import Layout from '@/layouts/Layout.astro'
import { Image } from 'astro:assets'

// Custom
import heroImageOne from '/public/hero/1.png'
import heroImageTwo from '/public/hero/2.png'
---

<!-- OUTLINE (basically it should be a ME page)
  - Hero Section With SubSection and text
  - Image Gallery of Me (bento box style)
-->
<Layout class="max-w-3xl">
  <PageHead slot="head" title="About" />
  <Breadcrumbs items={[{ label: 'About', icon: 'lucide:user-star' }]} />
  <div class="about-page flex flex-col gap-y-8">
    <!-- Header section with profile photos -->
    <section
      class="bg-grid-pattern flex flex-col items-center gap-6 p-6 pb-0 text-center"
    >
      <div class="relative flex items-center justify-center">
        <!-- one Profile -->
        <div
          class="group relative z-0 w-42 -rotate-2 bg-white p-2 pb-10 shadow-lg transition-all duration-300 hover:scale-105 hover:rotate-[-4deg] hover:shadow-xl"
        >
          <Image
            src={heroImageOne}
            alt="Profile 1"
            class="relative block h-auto w-full border border-gray-200"
          />
          <p
            class="font-caveat absolute bottom-2 left-1/2 -translate-x-1/2 text-base whitespace-nowrap text-gray-800"
          >
            me again :)
          </p>
        </div>
        <!-- two Profile -->
        <div
          class="group relative z-10 -ml-8 w-48 translate-y-14 rotate-2 bg-white p-2 pb-10 shadow-lg transition-all duration-300 hover:scale-105 hover:rotate-4 hover:shadow-xl"
        >
          <Image
            src={heroImageTwo}
            alt="Profile 2"
            class="relative block h-auto w-full border border-gray-200"
          />
          <p
            class="font-caveat absolute bottom-2 left-1/2 -translate-x-1/2 text-base whitespace-nowrap text-gray-800"
          >
            the other me
          </p>
        </div>
      </div>
      <h1 class="font-bon-vivant pt-10 text-8xl font-bold">
        who's <br />
        <span class="text-accent font-caveat -mt-10 block text-7xl font-black"
          >Shyne?</span
        >
      </h1>
    </section>

    <!-- About Me Section -->
    <section>
      <div>
        <p
          class="prose prose-sm text-muted-foreground max-w-none text-center font-serif md:text-left"
        >
          Hi, I'm Shyne — a passionate developer who loves turning ideas into
          reality through code. With a background in computer science and years
          of hands-on experience in full-stack development, I specialize in
          building performant, accessible, and beautiful web applications.
        </p>
        <p
          class="prose prose-sm text-muted-foreground mt-4 max-w-none text-center font-serif md:text-left"
        >
          My journey started with curiosity about how websites work, which led
          me to dive deep into HTML, CSS, and JavaScript. Over time, I expanded
          my toolkit to include modern frameworks like React, Vue, and of
          course, Astro — which inspired this very theme!
        </p>
        <p
          class="prose prose-sm text-muted-foreground mt-4 max-w-none text-center font-serif md:text-left"
        >
          When I'm not coding, you'll find me exploring open-source projects,
          writing technical articles, or contributing to the developer
          community. I believe in continuous learning and always staying curious
          about new technologies.
        </p>
      </div>
    </section>

    <!-- Tools Section -->
    <section>
      <h2 class="font-bon-vivant text-accent mb-4 text-5xl font-semibold">
        Tools, <span class="text-foreground font-sans text-4xl">you ask?</span>
      </h2>

      <ul
        class="text-muted-foreground mt-4 grid grid-cols-1 gap-3 text-left font-serif"
      >
        <li class="flex items-start gap-2">
          <span class="text-accent shrink-0">▹</span>
          <span class="inline-block">
            <strong class="text-foreground">Productivity:</strong> Obsidian / Zotero
            / V2ray / Clash Verge
          </span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-accent shrink-0">▹</span>
          <span class="inline-block">
            <strong class="text-foreground">Development:</strong> VS Code / Cursor
          </span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-accent shrink-0">▹</span>
          <span class="inline-block">
            <strong class="text-foreground">Design:</strong> Figma / Slidev /
            <a
              href="https://realfavicongenerator.net/"
              target="_blank"
              class="hover:text-accent underline underline-offset-4 transition-colors"
              >RealFaviconGenerator</a
            >(A one-stop favicon generator for all platforms)
          </span>
        </li>
      </ul>
    </section>

    <!-- Website Overview Section -->
    <section>
      <h2 class="text-accent font-bon-vivant mb-4 text-6xl font-semibold">
        <span class="relative -top-1 inline-block">Website</span>
        <span class="text-foreground font-sans text-4xl">& Overview</span>
      </h2>

      <p
        class="text-muted-foreground max-w-3xl text-center font-serif leading-relaxed md:text-left"
      >
        This site is supported by resources and technical services from the
        following projects/providers:
      </p>
      <ul
        class="text-muted-foreground mt-4 flex flex-col space-y-2 text-left font-serif"
      >
        <li class="flex items-start gap-2">
          <span class="text-accent shrink-0">▹</span>
          <span class="inline-block">
            <strong class="text-foreground">Domain registration:</strong> Spaceship
          </span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-accent shrink-0">▹</span>
          <span class="inline-block">
            <strong class="text-foreground">DNS resolution and proxy:</strong> Cloudflare
          </span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-accent shrink-0">▹</span>
          <span class="inline-block">
            <strong class="text-foreground">Web hosting:</strong> Vercel
          </span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-accent shrink-0">▹</span>
          <span class="inline-block">
            <strong class="text-foreground">Framework & theme:</strong>
            Astro +
            <a
              href="https://github.com/FuTseYi/Astro-Theme-Shyne"
              target="_blank"
              class="hover:text-accent underline underline-offset-4 transition-colors"
              >Astro-Theme-Shyne</a
            >
          </span>
        </li>
      </ul>
    </section>
  </div>
</Layout>
