---
// Components
import Breadcrumbs from '@/components/base/Breadcrumbs.astro'
import PageHead from '@/components/posts/base/PageHead.astro'

// Layouts
import Layout from '@/layouts/Layout.astro'
import { Image } from 'astro:assets'

// Custom
import heroImageOne from '/public/hero/1.png'
import heroImageTwo from '/public/hero/2.png'
---

<!-- OUTLINE (basically it should be a ME page)
  - Hero Section With SubSection and text
  - Image Gallery of Me (bento box style)
-->
<Layout class="max-w-3xl">
  <PageHead slot="head" title="About" />
  <Breadcrumbs items={[{ label: 'About', icon: 'lucide:user-star' }]} />
  <div class="about-page flex flex-col gap-y-8">
    <!-- Header section with profile photos -->
    <section
      class="bg-grid-pattern flex flex-col items-center gap-6 p-6 pb-0 text-center"
    >
      <div class="relative flex items-center justify-center">
        <!-- one Profile -->
        <div
          class="group relative z-0 w-42 -rotate-2 bg-white p-2 pb-10 shadow-lg transition-all duration-300 hover:scale-105 hover:rotate-[-4deg] hover:shadow-xl"
        >
          <Image
            src={heroImageOne}
            alt="Profile 1"
            class="relative block h-auto w-full border border-gray-200"
          />
          <p
            class="font-caveat absolute bottom-2 left-1/2 -translate-x-1/2 text-base whitespace-nowrap text-gray-800"
          >
            me again :)
          </p>
        </div>
        <!-- two Profile -->
        <div
          class="group relative z-10 -ml-8 w-48 translate-y-14 rotate-2 bg-white p-2 pb-10 shadow-lg transition-all duration-300 hover:scale-105 hover:rotate-4 hover:shadow-xl"
        >
          <Image
            src={heroImageTwo}
            alt="Profile 2"
            class="relative block h-auto w-full border border-gray-200"
          />
          <p
            class="font-caveat absolute bottom-2 left-1/2 -translate-x-1/2 text-base whitespace-nowrap text-gray-800"
          >
            the other me
          </p>
        </div>
      </div>
      <h1 class="font-bon-vivant pt-10 text-8xl font-bold">
        who's <br />
        <span class="text-accent font-caveat -mt-10 block text-7xl font-black"
          >Shyne?</span
        >
      </h1>
    </section>

    <!-- About Me Section -->
    <section>
      <div>
        <p
          class="prose prose-sm text-muted-foreground max-w-none text-center font-serif md:text-left"
        >
          Hi, I'm Shyne — a passionate developer who loves turning ideas into reality through code.
          With a background in computer science and years of hands-on experience in full-stack development,
          I specialize in building performant, accessible, and beautiful web applications.
        </p>
        <p
          class="prose prose-sm text-muted-foreground mt-4 max-w-none text-center font-serif md:text-left"
        >
          My journey started with curiosity about how websites work, which led me to dive deep into HTML, CSS,
          and JavaScript. Over time, I expanded my toolkit to include modern frameworks like React, Vue,
          and of course, Astro — which inspired this very theme!
        </p>
        <p
          class="prose prose-sm text-muted-foreground mt-4 max-w-none text-center font-serif md:text-left"
        >
          When I'm not coding, you'll find me exploring open-source projects, writing technical articles,
          or contributing to the developer community. I believe in continuous learning and always staying
          curious about new technologies.
        </p>
      </div>
    </section>

    <!-- Skills Section -->
    <section>
      <h2 class="font-bon-vivant text-accent mb-4 text-5xl font-semibold">
        skills, <span class="text-foreground font-sans text-4xl">you ask?</span>
      </h2>

      <p
        class="prose prose-sm text-muted-foreground max-w-3xl text-center font-serif leading-relaxed md:text-left"
      >
        Here's what I bring to the table:
      </p>
      <ul class="mt-4 grid grid-cols-2 gap-3 text-left font-serif text-muted-foreground">
        <li class="flex items-center gap-2">
          <span class="text-accent">▹</span> JavaScript / TypeScript
        </li>
        <li class="flex items-center gap-2">
          <span class="text-accent">▹</span> React / Next.js / Vue
        </li>
        <li class="flex items-center gap-2">
          <span class="text-accent">▹</span> Node.js / Python
        </li>
        <li class="flex items-center gap-2">
          <span class="text-accent">▹</span> Astro / Tailwind CSS
        </li>
        <li class="flex items-center gap-2">
          <span class="text-accent">▹</span> PostgreSQL / MongoDB
        </li>
        <li class="flex items-center gap-2">
          <span class="text-accent">▹</span> Docker / AWS / CI/CD
        </li>
      </ul>
      <p
        class="prose prose-sm text-muted-foreground mt-4 max-w-3xl text-center font-serif leading-relaxed md:text-left"
      >
        I'm always learning and staying up-to-date with the latest best practices.
        Feel free to check out my projects to see these skills in action!
      </p>
    </section>

    <!-- Interests Section -->
    <section>
      <h2 class="text-accent font-bon-vivant mb-4 text-6xl font-semibold">
        <span class="relative -top-1 inline-block">hobbies</span>
        <span class="text-foreground font-sans text-4xl">& stuff</span>
      </h2>

      <p
        class="text-muted-foreground max-w-3xl text-center font-serif leading-relaxed md:text-left"
      >
        Beyond coding, I have a variety of interests that keep me inspired:
      </p>
      <ul class="mt-4 space-y-2 text-left font-serif text-muted-foreground">
        <li class="flex items-center gap-2">
          <span class="text-accent">▹</span>
          <strong class="text-foreground">Open Source:</strong> Contributing to and maintaining open-source projects
        </li>
        <li class="flex items-center gap-2">
          <span class="text-accent">▹</span>
          <strong class="text-foreground">Tech Blogging:</strong> Writing articles about web development, tutorials, and best practices
        </li>
        <li class="flex items-center gap-2">
          <span class="text-accent">▹</span>
          <strong class="text-foreground">Photography:</strong> Capturing moments, especially travel and nature shots
        </li>
        <li class="flex items-center gap-2">
          <span class="text-accent">▹</span>
          <strong class="text-foreground">Gaming:</strong> Playing strategy and RPG games (coding + gaming = life!)
        </li>
        <li class="flex items-center gap-2">
          <span class="text-accent">▹</span>
          <strong class="text-foreground">Reading:</strong> Tech books, sci-fi novels, and developer podcasts
        </li>
      </ul>
      <p
        class="text-muted-foreground mt-4 max-w-3xl text-center font-serif leading-relaxed md:text-left"
      >
        Feel free to connect with me if you share similar interests or want to collaborate on something cool!
      </p>
    </section>
  </div>
</Layout>
