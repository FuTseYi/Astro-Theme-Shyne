# Import Type: "blog", "photos", or "all"
IMPORT_TYPE="all"

# Import Mode:
#   "update" - Import new files and update modified files (default, recommended)
#   "force"  - Force overwrite all existing files
#   "skip"   - Only import new files, skip existing files
IMPORT_MODE="force"

# Blog Source
SOURCE_BLOG_DIR="C:/Users/Xieyi/Desktop/Obsidian/My_Website_Blog"
# Attachment directory can be same as markdown dir or a separate location
SOURCE_BLOG_ATTACHMENT_DIR="C:/Users/Xieyi/Desktop/Obsidian/My_Website_Blog"

# Photos Source
SOURCE_PHOTOS_DIR="C:/Users/Xieyi/Desktop/Obsidian/My_Website_Photos"
# Attachment directory can be same as markdown dir or a separate location
SOURCE_PHOTOS_ATTACHMENT_DIR="C:/Users/Xieyi/Desktop/Obsidian/My_Website_Photos"

# Target Directories (Output)
TARGET_BLOG_DIR="src/content/blog"
TARGET_PHOTOS_DIR="src/content/photos"